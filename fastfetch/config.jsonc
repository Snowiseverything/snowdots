    },
    {
      "type": "command",
      "key": "у±–Ё",
      "keyColor": "35",
      "text": "echo $(docker ps --format '{{.Names}}' | wc -l) containers / $(systemctl list-units --type=service --state=running | grep '.service' | wc -l) services",
      "shell": "/bin/sh"
    },
    {
      "type": "uptime",
