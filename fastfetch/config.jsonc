    },
    {
      "type": "gpu",
      "key": "у°Ќ›",
      "keyColor": "35"
    },
    {
	"type": "command",
  	"key": "у°”„",
  	"keyColor": "31",
  	"text": "if [ -f /sys/class/thermal/thermal_zone0/temp ]; then echo \"$(($(cat /sys/class/thermal/thermal_zone0/temp) / 1000))В°C\"; else vcgencmd measure_temp | sed 's/temp=//'; fi",
 	 "shell": "/bin/sh" 
},
    {
      "type": "disk",
      "key": "у°‹Љ",
