    },
    {
      "type": "custom",
      "format": " \u001b[90mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ Software Information в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ"
    },
    {
      "type": "os",
      "key": "у°Ј‡",
      "keyColor": "34"
    },
    {
      "type": "command",
      "key": "у°„‰",
      "keyColor": "31",
      "text": "birth_install=$(stat -c %W / | tr -d '-'); now=$(date +%s); echo $(( (now - birth_install) / 86400 )) days",
      "shell": "/bin/sh"
    },
    {
      "type": "localip",
      "key": "у°©џ",
