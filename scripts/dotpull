#!/bin/bash
# Smart Dotfile Pull

if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "❌ Error: Not inside a Git repository."
    exit 1
fi

REPO_NAME=$(basename $(git rev-parse --show-toplevel))
echo "🚀 Starting Dotfile Pull for [$REPO_NAME]..."

echo "📡 Fetching updates..."
git fetch --all

echo "🔄 Resetting local state..."
git reset --hard origin/main

if [ "$REPO_NAME" == "SnowPi-Dotfiles" ]; then
    echo "📦 Restowing configs..."
    stow scripts starship fish
fi

echo "✅ $REPO_NAME is now up to date!"
notify-send -u critical "Dotfiles" "Local environment reset to origin/main."
