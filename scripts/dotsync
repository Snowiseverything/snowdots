#!/bin/bash
# --------------------------------------------------------------------------
# SNOWSYNC v9.5 — The "Dual-System" Edition
# --------------------------------------------------------------------------
POTENTIAL_REPOS=("$HOME/SnowPi-Dotfiles" "$HOME/Dotfiles")
REPOS=()

# Only sync repos that actually exist on this machine
for R in "${POTENTIAL_REPOS[@]}"; do
    if [ -d "$R" ]; then
        REPOS+=("$R")
    fi
done

START_DIR=$(pwd)
HOSTNAME=$(hostname)

auto_heal() {
    echo "🔧 Auto-Healing Symlinks for $HOSTNAME..."
    # Core rule: Never use windowrulev2 as it is deprecated
    
    if [[ "$HOSTNAME" == "snowpi" ]]; then
        # SnowPi specific links
        ln -sf "$HOME/SnowPi-Dotfiles/starship/starship.toml" "$HOME/.config/starship.toml"
        ln -sf "$HOME/SnowPi-Dotfiles/scripts/dotsync" "$HOME/.local/bin/dotpush"
    else
        # CachyOS specific links
        ln -sf "$HOME/Dotfiles/starship/starship.toml" "$HOME/.config/starship.toml"
        ln -sf "$HOME/Dotfiles/scripts/dotsync" "$HOME/.local/bin/dotpush"
    fi
}

for REPO in "${REPOS[@]}"; do
    echo "---------------------------------------------------"
    echo "❄️  SnowSync: Harmonizing [$(basename "$REPO")]"
    cd "$REPO" || continue

    # Pull first to prevent "non-fast-forward" errors
    git pull origin main --no-rebase

    git add .
    CHANGES=$(git status --porcelain | sed 's/^...//' | tr '\n' ',' | sed 's/,$//')
    
    if [ ! -z "$CHANGES" ]; then
        git commit -m "sync | $HOSTNAME | Files: $CHANGES"
        git push origin main
    else
        echo "✨ Everything up to date."
    fi
done

auto_heal
cd "$START_DIR"
