#!/bin/bash
# --------------------------------------------------------------------------
# SNOWSYNC v11.2 — The "One File to Rule Them All" Edition
# --------------------------------------------------------------------------

# Order: Check CachyOS Dotfiles first, then SnowPi secondary
POTENTIAL_REPOS=("$HOME/Dotfiles" "$HOME/SnowPi-Dotfiles")
REPOS=()

for R in "${POTENTIAL_REPOS[@]}"; do
    if [ -d "$R" ]; then REPOS+=("$R"); fi
done

START_DIR=$(pwd)
HOSTNAME=$(hostname)

for REPO in "${REPOS[@]}"; do
    echo "---------------------------------------------------"
    echo "❄️  SnowSync: Harmonizing [$(basename "$REPO")]"
    cd "$REPO" || continue

    # STEP 1: Smart Pull (Safety Stash)
    echo "📥 Checking for remote updates..."
    git stash >/dev/null 2>&1
    git pull origin main --no-rebase
    git stash pop >/dev/null 2>&1
    
    # STEP 2: Detect Changes
    git add .
    CHANGES=$(git status --porcelain)

    # STEP 3: Smart Commit
    if [ ! -z "$CHANGES" ]; then
        # Detect the most modified file
        MAJOR_CHANGE=$(git diff --name-only | head -n 1)
        if [ -z "$MAJOR_CHANGE" ]; then MAJOR_CHANGE="new files"; fi
        
        MSG="sync | $HOSTNAME | updated $MAJOR_CHANGE"
        
        echo "📤 Committing: $MSG"
        git commit -m "$MSG"
    fi

    # STEP 4: Sync to GitLab
    echo "🚀 Syncing commits to remote..."
    git push origin main
done

# --- Auto-Heal Symlinks (Hostname Specific) ---
# Prevents icon/config conflicts between CachyOS and Raspbian
if [[ "$HOSTNAME" == "snowpi" ]]; then
    ln -sf "$HOME/SnowPi-Dotfiles/scripts/dotsync" "$HOME/.local/bin/dotsync"
    ln -sf "$HOME/SnowPi-Dotfiles/scripts/audit-dots.sh" "$HOME/.local/bin/audit-dots"
else
    # On freezer, we use the main Dotfiles repo
    ln -sf "$HOME/Dotfiles/scripts/dotsync" "$HOME/.local/bin/dotsync"
    ln -sf "$HOME/Dotfiles/scripts/audit-dots.sh" "$HOME/.local/bin/audit-dots"
fi

cd "$START_DIR"

~/Dotfiles/scripts/snow-audit.sh
