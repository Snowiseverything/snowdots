#!/bin/bash
# --------------------------------------------------------------------------
# SNOWSYNC v11.0 — The "Indestructible" Edition
# --------------------------------------------------------------------------
# Define potential repos; script only acts if the folder exists locally
POTENTIAL_REPOS=("$HOME/SnowPi-Dotfiles" "$HOME/Dotfiles")
REPOS=()

for R in "${POTENTIAL_REPOS[@]}"; do
    if [ -d "$R" ]; then REPOS+=("$R"); fi
done

START_DIR=$(pwd)
HOSTNAME=$(hostname)

for REPO in "${REPOS[@]}"; do
    echo "---------------------------------------------------"
    echo "❄️  SnowSync: Harmonizing [$(basename "$REPO")]"
    cd "$REPO" || continue

    # STEP 1: Always pull first. This prevents 99% of Git breakages.
    echo "📥 Checking for remote updates..."
    git pull origin main --no-rebase

    # STEP 2: Stage all changes
    git add .

    # STEP 3: Check if there's actually anything to commit
    CHANGES=$(git status --porcelain | sed 's/^...//' | tr '\n' ',' | sed 's/,$//')
    
    if [ ! -z "$CHANGES" ]; then
        echo "📤 Pushing local changes: $CHANGES"
        git commit -m "sync | $HOSTNAME | $(date +%Y-%m-%d) | Files: $CHANGES"
        git push origin main
    else
        echo "✨ Everything is already matched."
    fi
done

# --- Auto-Heal Symlinks (Hostname Specific) ---
# Ensures your Raspberry Pi icon (f315) or Arch icon remains system-appropriate
if [[ "$HOSTNAME" == "snowpi" ]]; then
    ln -sf "$HOME/SnowPi-Dotfiles/starship/starship.toml" "$HOME/.config/starship.toml"
    ln -sf "$HOME/SnowPi-Dotfiles/scripts/dotsync" "$HOME/.local/bin/dotsync"
else
    ln -sf "$HOME/Dotfiles/starship/starship.toml" "$HOME/.config/starship.toml"
    ln -sf "$HOME/Dotfiles/scripts/dotsync" "$HOME/.local/bin/dotsync"
fi

cd "$START_DIR"
