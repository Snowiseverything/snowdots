#!/bin/bash
# --------------------------------------------------------------------------
# SnowSync — Unified Dotfiles Sync
# --------------------------------------------------------------------------

HOSTNAME=$(hostname)
REPO="$HOME/Dotfiles"
CLOUD_REMOTE="gitlab"
PEER_REMOTE="snowpi"

if [ ! -d "$REPO" ]; then
    echo "❌ Dotfiles repo not found at $REPO"
    exit 1
fi

echo "❄️  SnowSync: [$(basename "$REPO")] on $HOSTNAME"
cd "$REPO" || exit 1

# Pull from GitLab
echo "📥 Pulling from $CLOUD_REMOTE..."
git stash >/dev/null 2>&1
git pull "$CLOUD_REMOTE" main --no-rebase 2>/dev/null
git stash pop >/dev/null 2>&1

# Commit local changes
git add .
CHANGES=$(git status --porcelain)

if [ ! -z "$CHANGES" ]; then
    MAJOR_CHANGE=$(git diff --name-only | head -n 1)
    if [ -z "$MAJOR_CHANGE" ]; then MAJOR_CHANGE="new files"; fi
    MSG="sync | $HOSTNAME | $MAJOR_CHANGE"
    echo "📤 Committing: $MSG"
    git commit -m "$MSG"
fi

# Push to GitLab
echo "🚀 Syncing to GitLab..."
git push "$CLOUD_REMOTE" main 2>/dev/null

# Push to peer machine
echo "📡 Syncing to $PEER_REMOTE..."
git push "$PEER_REMOTE" main 2>/dev/null || echo "⚠️  Peer offline"

cd ~

# Auto-heal symlinks
ln -sf "$REPO/scripts/dotsync" "$HOME/.local/bin/dotsync"

# OC sync
OC="$REPO/.opencode"
if [ -d "$OC" ]; then
    for f in AGENTS.md MEMORY.md SOUL.md opencode.json; do
        [ -L "$HOME/.opencode/$f" ] && ln -sf "$OC/$f" "$HOME/.opencode/$f"
    done
    [ -L "$HOME/.opencode/skills" ] && ln -sfn "$OC/skills" "$HOME/.opencode/skills"
fi

# Machine-specific
if [[ "$HOSTNAME" == "freezer" ]]; then
    [ -f "$REPO/scripts/snow-audit.sh" ] && bash "$REPO/scripts/snow-audit.sh"
elif [[ "$HOSTNAME" == "snowpi" ]]; then
    [ -f "$REPO/scripts/audit-dots.sh" ] && bash "$REPO/scripts/audit-dots.sh"
fi

echo "✅ Done"