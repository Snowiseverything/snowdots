#!/bin/bash
# --------------------------------------------------------------------------
# SnowSync v13 — Separate Repos Edition
# --------------------------------------------------------------------------

HOSTNAME=$(hostname)
REPO="$HOME/Dotfiles"

if [ ! -d "$REPO" ]; then
    echo "❌ Dotfiles repo not found at $REPO"
    exit 1
fi

cd "$REPO" || exit 1

# Machine-specific config
if [[ "$HOSTNAME" == "freezer" ]]; then
    REPO_NAME="snowdots"
    CLOUD_REMOTE="gitlab"
    CLOUD_URL="gitlab.com/sn0wman/snowdots"
    PEER_REMOTE="snowpi"
    PEER_URL="snowpi (LAN)"
elif [[ "$HOSTNAME" == "snowpi" ]]; then
    REPO_NAME="snowpi-dotfiles"
    CLOUD_REMOTE="origin"
    CLOUD_URL="gitlab.com/sn0wman/snowpi-dotfiles"
    PEER_REMOTE="freezer"
    PEER_URL="freezer (Tailscale)"
fi

# ── Banner ─────────────────────────────────────
clear 2>/dev/null || true
echo ""
echo "██████╗  ██████╗ ████████╗███████╗██╗   ██╗███╗   ██╗ ██████╗"
echo "██╔══██╗██╔═══██╗╚══██╔══╝██╔════╝╚██╗ ██╔╝████╗  ██║██╔════╝"
echo "██║  ██║██║   ██║   ██║   ███████╗ ╚████╔╝ ██╔██╗ ██║██║     "
echo "██║  ██║██║   ██║   ██║   ╚════██║  ╚██╔╝  ██║╚██╗██║██║     "
echo "██████╔╝╚██████╔╝   ██║   ███████║   ██║   ██║ ╚████║╚██████╗"
echo "╚═════╝  ╚═════╝    ╚═╝   ╚══════╝   ╚═╝   ╚═╝  ╚═══╝ ╚═════╝"
echo ""
echo "  ┌─ Host:  $HOSTNAME"
echo "  ├─ Repo:  $REPO_NAME"
echo "  ├─ Push:  $CLOUD_URL"
echo "  ├─ Peer:  $PEER_URL"
if [[ "$HOSTNAME" == "freezer" ]]; then
    echo "  └─ GH:    github.com/Snowiseverything/snowdots (public, sanitized)"
else
    echo "  └─ GH:    —"
fi
echo "───────────────────────────────────────────────"

# Commit local changes first (avoids template flash from stash)
CHANGES=$(git status --porcelain)

if [ ! -z "$CHANGES" ]; then
    FIRST_CHANGE=$(echo "$CHANGES" | head -1 | sed 's/^.. //' | sed 's/\/.*//')
    MSG="sync | $HOSTNAME | $FIRST_CHANGE"
    echo "📤 Committing: $MSG"
    git add .
    git commit -m "$MSG"
fi

# Pull from cloud (no stash needed — clean tree)
echo "📥 Pulling from $CLOUD_REMOTE..."
git pull "$CLOUD_REMOTE" main --no-rebase 2>/dev/null || echo "⚠️  Pull failed"

# Push to cloud
echo "🚀 Syncing to $CLOUD_REMOTE..."
git push "$CLOUD_REMOTE" main 2>/dev/null

# Push to peer
echo "📡 Syncing to $PEER_REMOTE..."
git push "$PEER_REMOTE" main 2>/dev/null || echo "⚠️  Peer offline"

cd ~

# Auto-heal symlinks
ln -sf "$REPO/scripts/dotsync" "$HOME/.local/bin/dotsync"

# Machine-specific audit
if [[ "$HOSTNAME" == "freezer" ]]; then
    [ -f "$REPO/scripts/snow-audit.sh" ] && bash "$REPO/scripts/snow-audit.sh"
elif [[ "$HOSTNAME" == "snowpi" ]]; then
    [ -f "$REPO/scripts/audit-dots.sh" ] && bash "$REPO/scripts/audit-dots.sh"
fi

# Ask about GitHub publish (Freezer only)
if [[ "$HOSTNAME" == "freezer" ]]; then
    echo ""
    read -rp "📢 Publish sanitized version to GitHub? [y/N] " publish_gh
    case "$publish_gh" in
        [yY]|[yY][eE][sS])
            bash "$REPO/scripts/publish-public.sh"
            ;;
        *)
            echo "⏭️  Skipped GitHub publish"
            ;;
    esac
fi

echo "✅ Done"