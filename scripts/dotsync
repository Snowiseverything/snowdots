#!/bin/bash
# --------------------------------------------------------------------------
# SnowSync v13 вҖ” Separate Repos Edition
# --------------------------------------------------------------------------

HOSTNAME=$(hostname)
REPO="$HOME/Dotfiles"

if [ ! -d "$REPO" ]; then
    echo "вқҢ Dotfiles repo not found at $REPO"
    exit 1
fi

cd "$REPO" || exit 1

# Machine-specific config
if [[ "$HOSTNAME" == "freezer" ]]; then
    REPO_NAME="snowdots"
    CLOUD_REMOTE="gitlab"
    CLOUD_URL="gitlab.com/sn0wman/snowdots"
    PEER_REMOTE="snowpi"
    PEER_URL="snowpi (LAN)"
elif [[ "$HOSTNAME" == "snowpi" ]]; then
    REPO_NAME="snowpi-dotfiles"
    CLOUD_REMOTE="origin"
    CLOUD_URL="gitlab.com/sn0wman/snowpi-dotfiles"
    PEER_REMOTE="freezer"
    PEER_URL="freezer (Tailscale)"
fi

# в”Җв”Җ Banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
clear 2>/dev/null || true
echo ""
echo "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
echo "в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ"
echo "в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     "
echo "в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘  в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     "
echo "в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
echo "в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ    в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ"
echo ""
echo "  в”Ңв”Җ Host:  $HOSTNAME"
echo "  в”ңв”Җ Repo:  $REPO_NAME"
echo "  в”ңв”Җ Push:  $CLOUD_URL"
echo "  в”ңв”Җ Peer:  $PEER_URL"
if [[ "$HOSTNAME" == "freezer" ]]; then
    echo "  в””в”Җ GH:    github.com/Snowiseverything/snowdots (public, sanitized)"
else
    echo "  в””в”Җ GH:    вҖ”"
fi
echo "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"

# в”Җв”Җ Sync в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
CHANGES=$(git status --porcelain)
CHANGE_COUNT=$(echo "$CHANGES" | grep -c . || echo 0)

if [ "$CHANGE_COUNT" -gt 0 ]; then
    FIRST_CHANGE=$(echo "$CHANGES" | head -1 | sed 's/^.. //' | sed 's/\/.*//')
    MSG="sync | $HOSTNAME | $FIRST_CHANGE"
    echo "рҹ“Ө Committing $CHANGE_COUNT file(s): $MSG"
    git add .
    git commit -m "$MSG"
fi

echo "рҹ“Ҙ Pulling from $CLOUD_URL..."
git pull "$CLOUD_REMOTE" main --no-rebase 2>/dev/null || echo "вҡ пёҸ  Pull failed"

echo "рҹҡҖ Pushing to $CLOUD_URL..."
git push "$CLOUD_REMOTE" main 2>/dev/null

echo "рҹ“Ў Pushing to $PEER_URL..."
git push "$PEER_REMOTE" main 2>/dev/null || echo "вҡ пёҸ  Peer offline"

# в”Җв”Җ Sync Summary в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo ""
echo "  в—Ҳ Sync Summary в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
echo "    $CLOUD_URL    вң… Synced  (private)"
if [ "$CHANGE_COUNT" -gt 0 ]; then
    echo "    files                         $CHANGE_COUNT changed"
fi
if [[ "$HOSTNAME" == "freezer" ]]; then
    echo "    github.com/Snowiseverything     вҸёпёҸ  Pending (ask below)"
fi
echo "    $PEER_URL            вң… Pushed"
echo "  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"

cd ~

# Auto-heal symlinks
ln -sf "$REPO/scripts/dotsync" "$HOME/.local/bin/dotsync"

# Machine-specific audit
if [[ "$HOSTNAME" == "freezer" ]]; then
    [ -f "$REPO/scripts/snow-audit.sh" ] && bash "$REPO/scripts/snow-audit.sh"
elif [[ "$HOSTNAME" == "snowpi" ]]; then
    [ -f "$REPO/scripts/audit-dots.sh" ] && bash "$REPO/scripts/audit-dots.sh"
fi

# Ask about GitHub publish (Freezer only)
if [[ "$HOSTNAME" == "freezer" ]]; then
    echo ""
    read -rp "рҹ“ў Publish sanitized version to GitHub? [y/N] " publish_gh
    case "$publish_gh" in
        [yY]|[yY][eE][sS])
            bash "$REPO/scripts/publish-public.sh"
            ;;
        *)
            echo "вҸӯпёҸ  Skipped GitHub publish"
            ;;
    esac
fi

echo "вң… Done"