#!/bin/bash
# Smart Dotfile Sync

if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "❌ Error: Not inside a Git repository."
    exit 1
fi

REPO_NAME=$(basename $(git rev-parse --show-toplevel))
echo "🚀 Starting Dotfile Sync for [$REPO_NAME]..."

echo "📦 Staging changes..."
git add .

if git diff-index --quiet HEAD --; then
    echo "✨ No changes to sync in $REPO_NAME."
else
    echo "📝 Committing update..."
    git commit -m "update $(date +%Y-%m-%d)"

    # Push to all remotes with a connectivity check
    for remote in $(git remote); do
        URL=$(git remote get-url "$remote")
        
        # Check if the remote is your workstation IP
        if [[ "$URL" == *"100.87.27.79"* ]]; then
            if ! ping -c 1 -W 1 100.87.27.79 > /dev/null 2>&1; then
                echo "⏭️  Skipping $remote: Workstation is offline (Freezer)."
                continue
            fi
        fi

        echo "📡 Pushing to $remote..."
        git push "$remote" main
    done
fi

echo "✅ $REPO_NAME sync complete!"

# Only notify if notify-send exists (prevents errors on headless SnowPi)
command -v notify-send >/dev/null && notify-send -i software-update-available "Dotfiles" "Remote repositories updated successfully."
