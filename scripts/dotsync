#!/bin/bash
# --------------------------------------------------------------------------
# SNOWSYNC v11.6 — The "Named Nodes" Edition
# --------------------------------------------------------------------------

POTENTIAL_REPOS=("$HOME/Dotfiles")
REPOS=()

for R in "${POTENTIAL_REPOS[@]}"; do
    if [ -d "$R" ]; then REPOS+=("$R"); fi
done

START_DIR=$(pwd)
HOSTNAME=$(hostname)

CLOUD_REMOTE="gitlab"
PEER_REMOTE="snowpi"

for REPO in "${REPOS[@]}"; do
    echo "---------------------------------------------------"
    echo "❄️  SnowSync: Harmonizing [$(basename "$REPO")]"
    cd "$REPO" || continue

    # STEP 1: Smart Pull from Cloud
    echo "📥 Checking for remote updates..."
    git stash >/dev/null 2>&1
    git pull "$CLOUD_REMOTE" main --no-rebase
    git stash pop >/dev/null 2>&1
    
    # STEP 2: Detect Changes
    git add .
    CHANGES=$(git status --porcelain)

    # STEP 3: Smart Commit
    if [ ! -z "$CHANGES" ]; then
        MAJOR_CHANGE=$(git diff --name-only | head -n 1)
        if [ -z "$MAJOR_CHANGE" ]; then MAJOR_CHANGE="new files"; fi
        MSG="sync | $HOSTNAME | updated $MAJOR_CHANGE"
        echo "📤 Committing: $MSG"
        git commit -m "$MSG"
    fi

    # STEP 4: Multi-Node Sync
    echo "🚀 Syncing commits to all nodes..."
    
    # 1. Push to Cloud (GitLab)
    git push "$CLOUD_REMOTE" main
    
    # 2. Push to Peer Machine
    git push "$PEER_REMOTE" main 2>/dev/null || echo "⚠️  Peer push failed (offline?)"
    
    # 3. Push to Backup (if remote exists)
    if [[ "$HOSTNAME" == "snowpi" ]]; then
        git push snowpi main 2>/dev/null
    fi
done

# --- Auto-Heal Symlinks & Mirroring ---
ln -sf "$HOME/Dotfiles/scripts/dotsync" "$HOME/.local/bin/dotsync"
OC_SHARED="$HOME/Dotfiles/.opencode"

# Auto-heal OC symlinks
if [ -d "$OC_SHARED" ]; then
    for f in AGENTS.md MEMORY.md SOUL.md opencode.json; do
        [ -L "$HOME/.opencode/$f" ] && [ "$(readlink "$HOME/.opencode/$f")" != "$OC_SHARED/$f" ] &&
            ln -sf "$OC_SHARED/$f" "$HOME/.opencode/$f"
    done
    [ -L "$HOME/.opencode/skills" ] && [ "$(readlink "$HOME/.opencode/skills")" != "$OC_SHARED/skills" ] &&
        ln -sfn "$OC_SHARED/skills" "$HOME/.opencode/skills"
fi

cd "$START_DIR"
# Only run mirror if the directory exists (prevents errors on Pi if not mounted)
[ -d "$HOME/Dotfiles" ] && bash "$HOME/Dotfiles/scripts/dot-mirror.sh"
[ -f "$HOME/Dotfiles/scripts/snow-audit.sh" ] && ~/Dotfiles/scripts/snow-audit.sh
