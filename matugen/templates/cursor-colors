#!/bin/bash
# SnowDots - Cursor color updater from matugen
# Usage: Add to matugen post_processing or run manually after wallpaper change

CURSOR_DIR="$HOME/.local/share/icons"
THEME_NAME="Adwaita"

# Extract primary color from matugen colors
if [ -f "$HOME/.config/matugen/colors.json" ]; then
    PRIMARY=$(cat "$HOME/.config/matugen/colors.json" | jq -r '.primary.default.hex' 2>/dev/null)
    
    if [ -n "$PRIMARY" ] && [ "$PRIMARY" != "null" ]; then
        # Create a simple color-swap script for the cursor
        # This would need actual cursor theme editing - complex
        echo "Primary color for cursor: $PRIMARY"
        # For now, set the cursor via gsettings
        gsettings set org.gnome.desktop.interface cursor-theme "Adwaita"
    fi
fi